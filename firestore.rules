rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each lender owns their own subtree.
    // No lender can read or write another lender's data.
    match /users/{lenderId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == lenderId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
